# Dinero Futuro — variables de entorno
# Copia este archivo a .env.local y completa los valores

# ── OBLIGATORIAS ──────────────────────────────────────────────────────────────

# URL del sitio (sin barra final)
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# Nombre del sitio
NEXT_PUBLIC_SITE_NAME=Dinero Futuro

# ── GENERACIÓN AUTOMÁTICA ─────────────────────────────────────────────────────

# Clave API de Anthropic (para generar artículos automáticamente)
# Consíguelo en: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── CAPTURA DE EMAILS ─────────────────────────────────────────────────────────

# Webhook de Google Sheets para guardar emails de suscriptores
# Instrucciones en SETUP.md → sección "Google Sheets"
# Si no está configurado, los emails se loguean en consola (solo desarrollo)
GOOGLE_SHEET_WEBHOOK_URL=https://script.google.com/macros/s/TU_ID/exec

# ── ANALYTICS (OPCIONAL) ─────────────────────────────────────────────────────

# Google Analytics 4
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
